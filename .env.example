# ═══════════════════════════════════════════════════════════
# MochiBot — Environment Configuration
# Copy this file to .env and fill in your values
# For the full list of ~70 tunables, see mochi/config.py
# ═══════════════════════════════════════════════════════════

# ── Chat Model (required) ────────────────────────────────
# CHAT_PROVIDER tells the framework which SDK to use:
#   "openai"       — also works with DeepSeek, Ollama, Groq, Together AI, etc.
#   "azure_openai" — Azure OpenAI
#   "anthropic"    — Anthropic Claude
CHAT_PROVIDER=openai
CHAT_API_KEY=your-api-key-here
CHAT_MODEL=                    # required — e.g. gpt-4o, deepseek-chat, claude-sonnet-4-20250514
# CHAT_BASE_URL=               # custom endpoint, e.g. http://localhost:11434/v1

# ── Think Model (optional, falls back to Chat) ──────────
# Heartbeat Think + nightly maintenance can use a cheaper / faster model.
# Each field independently falls back to the Chat value when empty.
# THINK_PROVIDER=
# THINK_API_KEY=
# THINK_MODEL=
# THINK_BASE_URL=

# ── Azure-specific (only when provider = azure_openai) ──
# AZURE_API_VERSION=2024-12-01-preview

# ── 3-Tier Model Routing (optional, advanced) ───────────
# These values are auto-imported to DB on first startup.
# After that, manage models via the admin portal.
# If all tiers are empty, they fall back to the Chat config above.
# TIER_LITE_PROVIDER=
# TIER_LITE_API_KEY=
# TIER_LITE_MODEL=
# TIER_LITE_BASE_URL=
# TIER_CHAT_PROVIDER=
# TIER_CHAT_API_KEY=
# TIER_CHAT_MODEL=
# TIER_CHAT_BASE_URL=
# TIER_DEEP_PROVIDER=
# TIER_DEEP_API_KEY=
# TIER_DEEP_MODEL=
# TIER_DEEP_BASE_URL=

# ── Embedding / Vector Search (optional) ─────────────────
# Enables vector-enhanced memory recall. Without this, memory uses keyword search only.
# Providers: openai, azure_openai, ollama, none
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=                          # required for ollama (e.g. http://localhost:11434/v1)
#
# Legacy Azure vars (still work if EMBEDDING_PROVIDER is not set):
# AZURE_EMBEDDING_ENDPOINT=
# AZURE_EMBEDDING_API_KEY=
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_EMBEDDING_API_VERSION=2024-10-21
#
# EMBEDDING_CACHE_MAX_SIZE=128
# EMBEDDING_CACHE_TTL_S=300
#
# Native vector KNN search (requires: pip install sqlite-vec)
# Without sqlite-vec, recall falls back to keyword + Python cosine — works, just slower.
# VEC_SEARCH_NATIVE_ENABLED=true
# VEC_EMBEDDING_DIM=1536

# ── Transport — Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Transport — WeChat (optional) ────────────────────────
# Run `python weixin_auth.py` to scan QR code and get your token.
# WEIXIN_ENABLED=false
# WEIXIN_BOT_TOKEN=
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
# WEIXIN_ALLOWED_USERS=                # comma-separated; empty = allow all
# WEIXIN_POLL_TIMEOUT_S=35
# WEIXIN_BUBBLE_DELAY_S=1.0
# WEIXIN_MSG_LIMIT=4000
# WEIXIN_BACKOFF_MIN_S=2               # min backoff delay on poll error (seconds)
# WEIXIN_BACKOFF_MAX_S=30              # max backoff delay on poll error (seconds)
# WEIXIN_MAX_CONSECUTIVE_FAILURES=3    # failures before session-level reconnect
# WEIXIN_SESSION_EXPIRED_RETRY_S=300   # retry interval after session expiry (seconds)

# ── Heartbeat ────────────────────────────────────────────
# These values are auto-imported to DB on first startup.
# After that, manage via admin portal — changes here won't take effect.
HEARTBEAT_INTERVAL_MINUTES=20
MAX_DAILY_PROACTIVE=10
# Advanced (usually no need to change):
# PROACTIVE_COOLDOWN_SECONDS=1800    # min gap between proactive messages
# THINK_FALLBACK_MINUTES=60          # force Think even without deltas
# LLM_HEARTBEAT_TIMEOUT_SECONDS=120  # timeout for LLM calls in heartbeat loop
# PROACTIVE_CHAT_MAX_TOKENS=512     # max tokens for proactive message generation
# PROACTIVE_CHAT_HISTORY_TURNS=10   # conversation context for proactive messages
# AWAKE_HOUR_START=7                 # DEPRECATED
# AWAKE_HOUR_END=23                  # DEPRECATED

# ── Sleep/Wake State Machine ─────────────────────────────
# Simplified: sleep triggers after 21:00 (keyword or 1hr silence).
# Wake: user message after 6 AM, or fallback auto-wake.
# FALLBACK_WAKE_HOUR=10              # auto wake-up hour (admin-configurable)
# SILENCE_PAUSE_DAYS=3.0             # days of silence → pause all proactive
# Advanced overrides (not in admin UI):
# WAKE_EARLIEST_HOUR=6               # don't wake on user msg before this hour
# SLEEP_AFTER_HOUR=21                # keyword + silence sleep checks start here
# SILENCE_THRESHOLD_HOURS=1.0        # hours of silence after SLEEP_AFTER_HOUR → sleep
# SLEEP_KEYWORDS=晚安,睡了,去睡了,good night,gn

# ── Memory ───────────────────────────────────────────────
MEMORY_EXTRACT_INTERVAL_HOURS=4
CORE_MEMORY_MAX_TOKENS=800
COMPRESS_DAILY_AFTER_DAYS=7
COMPRESS_WEEKLY_AFTER_DAYS=30
# TRASH_PURGE_DAYS=30

# ── Memory Lifecycle ─────────────────────────────────────
# MEMORY_DEMOTE_AFTER_DAYS=60       # demote rarely-accessed memories after N days
# MEMORY_DEMOTE_MIN_ACCESS=3        # min access count to avoid demotion
# RECALL_DECAY_HALF_LIFE_DAYS=30    # recency decay half-life for recall scoring

# ── Memory Recall Weights ────────────────────────────────
# RECALL_VEC_SIM_THRESHOLD=0.25     # min cosine similarity for vector matches
# RECALL_BM25_WEIGHT=2.0            # weight for BM25 text search
# RECALL_VEC_SIM_WEIGHT=6.0         # weight for vector similarity
# RECALL_KEYWORD_BOOST=1.0          # bonus score when BM25 keyword match exists
# RECALL_FTS_CANDIDATE_MULTIPLIER=5 # expand FTS candidates: limit * N
# RECALL_FALLBACK_LIMIT=100         # max candidates before scoring phase
# VEC_SEARCH_CANDIDATE_LIMIT=50     # max K for vec0 KNN search

# ── Memory Auto-Recall (pre-turn retrieval) ─────────────
# Automatically retrieves relevant memories before each LLM call.
# Requires embedding provider above. Gracefully disabled if no embedding configured.
# MEMORY_AUTO_RECALL=true             # master switch (default: on)
# MEMORY_AUTO_RECALL_TOP_K=5          # candidates to retrieve before filtering
# MEMORY_AUTO_RECALL_MAX_ITEMS=3      # max memories injected into prompt
# MEMORY_AUTO_RECALL_MIN_VEC_SIM=0.35 # min cosine similarity to pass
# MEMORY_AUTO_RECALL_MIN_SCORE=0.72   # min normalized score (0-1) to pass
# MEMORY_AUTO_RECALL_MAX_CHARS=320    # max chars per memory snippet
# MEMORY_AUTO_RECALL_COOLDOWN=120     # seconds between recalls per user (0=disabled)

# ── Knowledge Graph (entity-relationship triples) ───────
# Structured memory layer: entities (people, pets, places) and relationships.
# Extracted nightly from conversations, injected into prompts when relevant.
# KG_ENABLED=true                    # master switch (default: on)
# KG_MAX_ENTITY_CONTEXT_TOKENS=300   # max tokens per entity in prompt
# KG_ENTITY_MATCH_MIN_LENGTH=2       # min entity name length to match
# KG_MAX_TRIPLES_PER_ENTITY=20       # max relationships per entity query

# ── Maintenance ──────────────────────────────────────────
# Auto-imported to DB on first startup. Manage via admin portal after that.
MAINTENANCE_HOUR=3
# MAINTENANCE_ENABLED=true

# ── Bedtime Tidy ─────────────────────────────────────────
# Evening review routine: tidy notes/todos and say goodnight at sleep transition.
# BEDTIME_TIDY_ENABLED=true
# BEDTIME_TIDY_TIMEOUT_S=60                # timeout for the entire bedtime tidy LLM call
# BEDTIME_TIDY_MAX_ROUNDS=5                # max tool-call rounds
# BEDTIME_TIDY_MAX_TOKENS=1024             # max response tokens
# BEDTIME_TIDY_TOOLS=manage_note,manage_todo  # tools available during bedtime tidy

# ── Diary ────────────────────────────────────────────────
# DIARY_STATUS_MAX_LINES=20
# DIARY_ENTRY_MAX_LINES=50

# ── Token Limits ─────────────────────────────────────────
# AI_CHAT_MAX_COMPLETION_TOKENS=4096
# TOOL_LOOP_MAX_ROUNDS=5
# TOOL_LOOP_PER_TOOL_LIMIT=5

# ── Tool Router / Governance ─────────────────────────────
# TOOL_ROUTER_ENABLED=true          # LLM-based skill selection (default: true)
# TOOL_ROUTER_MAX_TOKENS=100
# TOOL_ESCALATION_ENABLED=true      # mid-turn skill requests
# TOOL_ESCALATION_MAX_PER_TURN=2
# TOOL_DENY_NAMES=                  # comma-separated denylist of tool names
# TOOL_REQUIRE_CONFIRM=             # comma-separated tools requiring user confirmation
# TOOL_RATE_LIMIT_PER_MIN=10

# ── Chatty Rhythm (Telegram multi-bubble) ────────────────
# TG_INTERIM_ENABLED=true
# TG_BUBBLE_DELAY_S=1.0
# TG_BUBBLE_MAX=4
# TG_BUBBLE_DELIMITER=|||
# TG_BUBBLE_MIN_CHARS=8
# TG_AGGREGATE_ENABLED=true

# ── Observer Thresholds ──────────────────────────────────
# DELTA_SILENCE_JUMP_HOURS=1.5
# DELTA_NEW_TODOS=3
# OBSERVER_FAILURE_ALERT_THRESHOLD=3

# ── Weather Observer (optional, no API key needed) ──────
# WEATHER_CITY=Tokyo

# ── Log Compression (advanced) ───────────────────────────
# PET_LOG_WEEKLY_AFTER_DAYS=7
# PET_LOG_MONTHLY_AFTER_DAYS=30
# LIFE_LOG_WEEKLY_AFTER_DAYS=7
# LIFE_LOG_MONTHLY_AFTER_DAYS=30

# ── Database ─────────────────────────────────────────────
# HEARTBEAT_LOG_TRIM_DAYS=7
# HEARTBEAT_LOG_DELETE_DAYS=30

# ── Logging ──────────────────────────────────────────────
# LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ── General ──────────────────────────────────────────────
# Auto-imported to DB on first startup. Manage via admin portal after that.
TIMEZONE_OFFSET_HOURS=8

# ── Web Search ─────────────────────────────────────────
# Built-in DuckDuckGo search — no API key needed, works out of the box.
# WEB_SEARCH_TIMEOUT_S=20

# ── Oura Ring (optional) ────────────────────────────────
# Run `python oura_auth.py` to authorize and get your tokens.
# OURA_CLIENT_ID=
# OURA_CLIENT_SECRET=
# OURA_REFRESH_TOKEN=

# ── Owner Info ───────────────────────────────────────────
# Your Telegram user ID (for owner-only commands)
# OWNER_USER_ID=123456789

# ── Admin Portal (optional) ─────────────────────────────
# Web-based setup & config portal. Requires: pip install fastapi uvicorn
# ADMIN_ENABLED=true              # set false to disable the portal
# ADMIN_PORT=8080                 # port for the web portal
# ADMIN_BIND=127.0.0.1            # default: localhost only; set 0.0.0.0 for remote access
# ADMIN_TOKEN=                    # set a token to require auth; leave empty for open access
